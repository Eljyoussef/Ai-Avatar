{
  "dashboard": {
    "title": "Avatar Chatbot - Overview",
    "panels": [
      {
        "title": "Active Sessions",
        "type": "stat",
        "targets": [
          {
            "expr": "active_sessions_total",
            "legendFormat": "Active Sessions"
          }
        ]
      },
      {
        "title": "ASR Latency (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(asr_transcription_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "title": "TTS Buffer Health",
        "type": "graph",
        "targets": [
          {
            "expr": "tts_buffer_underrun_total",
            "legendFormat": "Underruns"
          }
        ]
      },
      {
        "title": "LLM Tokens/sec",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(vllm_tokens_generated_total[1m])",
            "legendFormat": "Tokens/s"
          }
        ]
      },
      {
        "title": "RAG Retrieval Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(rag_retrieval_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "title": "GPU Memory Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "nvidia_gpu_memory_used_bytes / nvidia_gpu_memory_total_bytes * 100",
            "legendFormat": "GPU {{gpu}}"
          }
        ]
      },
      {
        "title": "NATS Message Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(nats_msg_count_total[1m])",
            "legendFormat": "Messages/sec"
          }
        ]
      },
      {
        "title": "Accent Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "accent_classification_total",
            "legendFormat": "{{accent}}"
          }
        ]
      }
    ]
  }
}